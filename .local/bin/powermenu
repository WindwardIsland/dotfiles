#! /bin/sh

# Taken and modified from: https://github.com/ericmurphyxyz/dotfiles/blob/master/.local/bin/powermenu

chosen=$(printf "’Ćæ  Power Off\n’Ć×  Restart\n’ĆŻ  Lock" | rofi -dmenu -i -theme-str '@import "power.rasi"')

case "$chosen" in
	"’Ćæ  Power Off") systemctl poweroff ;;
	"’Ć×  Restart") systemctl reboot ;;
	"’ĆŻ  Lock") betterlockscreen -l dim ;;
	*) exit 1 ;;
esac
